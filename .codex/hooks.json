{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.parlance/hooks/session-start.js\"",
            "timeout": 5,
            "statusMessage": "Loading Parlance session state"
          }
        ],
        "matcher": "startup|resume|clear"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.parlance/hooks/user-prompt-submit.js\"",
            "timeout": 3,
            "statusMessage": "Checking Parlance prompt context"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.parlance/hooks/pre-tool.js\"",
            "timeout": 5,
            "statusMessage": "Checking Parlance routing"
          }
        ],
        "matcher": "Bash|apply_patch|Edit|Write|mcp__.*"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.parlance/hooks/post-tool.js\"",
            "timeout": 5,
            "statusMessage": "Recording Parlance tool telemetry"
          }
        ],
        "matcher": "Bash|apply_patch|Edit|Write|mcp__.*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.parlance/hooks/stop.js\"",
            "timeout": 10,
            "statusMessage": "Recording Parlance session summary"
          }
        ]
      }
    ]
  }
}