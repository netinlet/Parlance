{
  "name": "@parlance/agent-adapter-claude",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "parlance-agent-claude": "dist/cli.js"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsc -p tsconfig.build.json && node scripts/bundle.mjs",
    "lint": "eslint .",
    "format": "biome check --write .",
    "format:check": "biome ci .",
    "deadcode": "knip",
    "review": "npm run typecheck && npm run lint && npm test && npm run deadcode && npm run format:check"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@eslint/js": "^10.0.1",
    "@parlance/agent-core": "file:../Core",
    "@types/node": "^22.9.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.5.0",
    "knip": "6.16.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.5"
  }
}
