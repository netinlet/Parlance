# Isolated style config for the code-action integration fixtures. `root = true` stops resolution here so
# these files do NOT inherit the repo's prefer-var style — they pin prefer-explicit-type instead, which makes
# IDE0008 ("use explicit type instead of 'var'") fire deterministically on the var-heavy sample below,
# independent of whatever the repo `.editorconfig` happens to prefer.
root = true

[*.cs]
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = false:suggestion
csharp_style_var_elsewhere = false:suggestion
